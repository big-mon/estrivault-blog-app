{
  "name": "astro-blog",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "pnpm run generate:redirects && astro build",
    "generate:redirects": "node scripts/generate-redirects.mjs",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "eslint .",
    "format": "prettier --write .",
    "setup:e2e": "playwright install --with-deps chromium",
    "test:e2e": "playwright test",
    "test": "pnpm run test:e2e"
  },
  "dependencies": {
    "@estrivault/content-processor": "workspace:^",
    "@estrivault/og-image-generator": "workspace:^",
    "@resvg/resvg-js": "^2.6.2",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.6",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  }
}
