---
interface Props {
  homePage?: boolean;
}

const { homePage = false } = Astro.props;
const localPath = (hash: string) => (homePage ? hash : `/${hash}`);
---

<section class="editorial-masthead">
  <div class="brand"><a href="/">Estrilda</a></div>
  <nav aria-label="Primary navigation">
    <a href={localPath('#categories')}>CATEGORIES</a>
    <a href="/notes/">NOTES</a>
    <a href="/post/about">ABOUT</a>
    <a
      href="/llms.txt"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="LLMs"
      title="LLMs"
      class="icon-link"
    >
      <svg aria-hidden="true" width="22" height="22" viewBox="0 0 24 24">
        <path
          d="M11 2h2v3h3.5A3.5 3.5 0 0 1 20 8.5v6A3.5 3.5 0 0 1 16.5 18h-9A3.5 3.5 0 0 1 4 14.5v-6A3.5 3.5 0 0 1 7.5 5H11V2Zm-3.5 5A1.5 1.5 0 0 0 6 8.5v6A1.5 1.5 0 0 0 7.5 16h9a1.5 1.5 0 0 0 1.5-1.5v-6A1.5 1.5 0 0 0 16.5 7h-9ZM9 11a1.25 1.25 0 1 1 0-2.5A1.25 1.25 0 0 1 9 11Zm6 0a1.25 1.25 0 1 1 0-2.5A1.25 1.25 0 0 1 15 11Zm-5.5 2.5h5v1.5h-5v-1.5ZM2 10h2v3H2v-3Zm18 0h2v3h-2v-3Z"
        ></path>
      </svg>
    </a>
  </nav>
  <p class="tagline">投資、開発、AI、ゲーム、ギア、エッセイのアーカイブ。</p>
</section>

<style>
  .editorial-masthead {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.25rem 2rem;
    align-items: end;
    max-width: 1180px;
    margin-right: auto;
    margin-bottom: 1.05rem;
    margin-left: auto;
    border-bottom: 2px solid #202020;
    padding-top: 0.25rem;
    padding-bottom: 0.85rem;
  }

  .brand {
    font-family: var(--font-display);
    font-size: clamp(2.9rem, 5vw, 4.25rem);
    font-weight: 700;
    line-height: 0.84;
  }

  .brand a,
  nav a {
    color: #111;
    text-decoration: none;
    transition: color 120ms ease;
  }

  .brand a {
    font-family: var(--font-display);
    font-style: normal;
    font-weight: 700;
  }

  nav {
    display: flex;
    align-self: center;
    gap: clamp(1.4rem, 3vw, 3.8rem);
    border-bottom: 1px solid #222;
    padding: 0 0.9rem 0.55rem;
    font-family: var(--font-meta);
    font-size: 0.96rem;
    font-style: normal;
    letter-spacing: 0.02em;
  }

  nav a:hover {
    color: #d6452a;
  }

  .icon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.25rem;
    height: 1.25rem;
    margin-top: -0.1rem;
  }

  .icon-link svg {
    width: 1.25rem;
    height: 1.25rem;
    fill: currentColor;
  }

  .tagline {
    grid-column: 1;
    margin: 0;
    padding-top: 0.35rem;
    color: #555;
    font-family: var(--font-meta);
    font-size: 0.8rem;
    font-style: normal;
    line-height: 1.45;
  }

  @media (max-width: 900px) {
    .editorial-masthead {
      grid-template-columns: 1fr;
      gap: 0.8rem;
      margin-bottom: 1.25rem;
      padding-bottom: 1rem;
    }

    .brand {
      font-size: clamp(2.5rem, 12vw, 3.75rem);
    }

    nav {
      width: 100%;
      justify-content: space-between;
      gap: 0.75rem;
      padding-right: 0;
      padding-left: 0;
      white-space: nowrap;
    }
  }
</style>
