---
interface Props {
  homePage?: boolean;
}

const { homePage = false } = Astro.props;
const localPath = (hash: string) => (homePage ? hash : `/${hash}`);
---

<section class="editorial-masthead">
  <div class="brand"><a href="/">Estrilda</a></div>
  <nav aria-label="Primary navigation">
    <a href={localPath('#categories')}>CATEGORIES</a>
    <a href="/notes/">NOTES</a>
    <a href="/post/about">ABOUT</a>
  </nav>
  <p class="tagline">投資、開発、AI、ゲーム、ギア、エッセイのアーカイブ。</p>
</section>

<style>
  .editorial-masthead {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.25rem 2rem;
    align-items: end;
    max-width: 1180px;
    margin-right: auto;
    margin-bottom: 1.05rem;
    margin-left: auto;
    border-bottom: 2px solid #202020;
    padding-top: 0.25rem;
    padding-bottom: 0.85rem;
  }

  .brand {
    font-family: var(--font-display);
    font-size: clamp(2.9rem, 5vw, 4.25rem);
    font-weight: 700;
    line-height: 0.84;
  }

  .brand a,
  nav a {
    color: #111;
    text-decoration: none;
    transition: color 120ms ease;
  }

  .brand a {
    font-family: var(--font-display);
    font-style: normal;
    font-weight: 700;
  }

  nav {
    display: flex;
    align-self: center;
    gap: clamp(1.4rem, 3vw, 3.8rem);
    border-bottom: 1px solid #222;
    padding: 0 0.9rem 0.55rem;
    font-family: var(--font-meta);
    font-size: 0.96rem;
    font-style: normal;
    letter-spacing: 0.02em;
  }

  nav a:hover {
    color: #d6452a;
  }

  .tagline {
    grid-column: 1;
    margin: 0;
    padding-top: 0.35rem;
    color: #555;
    font-family: var(--font-meta);
    font-size: 0.8rem;
    font-style: normal;
    line-height: 1.45;
  }

  @media (max-width: 900px) {
    .editorial-masthead {
      grid-template-columns: 1fr;
      gap: 0.8rem;
      margin-bottom: 1.25rem;
      padding-bottom: 1rem;
    }

    .brand {
      font-size: clamp(2.5rem, 12vw, 3.75rem);
    }

    nav {
      width: 100%;
      justify-content: space-between;
      gap: 0.75rem;
      padding-right: 0;
      padding-left: 0;
      white-space: nowrap;
    }
  }
</style>
