---
import type { PostHTML } from '@estrivault/content-processor';

interface Props {
  post: PostHTML;
}

const { post } = Astro.props;

const proseClasses = [
  'post-prose',
  'prose',
  'max-w-none',
  post.hasTwitterEmbeds ? 'has-twitter-embeds' : '',
  post.hasAmazonEmbeds ? 'has-amazon-embeds' : '',
  post.hasCodeBlocks ? 'has-code-blocks' : '',
  post.hasDirectiveBoxes ? 'has-directive-boxes' : '',
]
  .filter(Boolean)
  .join(' ');
---

<div class="article-body">
  <div class="article-body__inner">
    <div class={proseClasses} set:html={post.html || 'コンテンツがありません'} />
  </div>

  <div class="article-body__backlink">
    <a href="/">← 記事一覧に戻る</a>
  </div>
</div>
