---
import type { HeadingInfo } from '@estrivault/content-processor';

interface Props {
  headings: HeadingInfo[];
}

const { headings } = Astro.props;

function getIndentClass(level: number): string {
  switch (level) {
    case 1:
    case 2:
      return 'ml-0';
    case 3:
      return 'ml-4';
    case 4:
      return 'ml-8';
    case 5:
      return 'ml-12';
    case 6:
      return 'ml-16';
    default:
      return 'ml-0';
  }
}

function getTextSizeClass(level: number): string {
  switch (level) {
    case 1:
    case 2:
      return 'text-base font-semibold';
    case 3:
    case 4:
      return 'text-sm';
    case 5:
    case 6:
      return 'text-xs';
    default:
      return 'text-sm';
  }
}
---

{
  headings.length > 0 && (
    <nav class="toc-panel">
      <p class="section-label">Jump List</p>
      <h2 class="toc-panel__title">目次</h2>
      <ul class="toc-panel__list">
        {headings.map((heading) => (
          <li
            class:list={[getIndentClass(heading.level), `toc-panel__item--level-${heading.level}`]}
          >
            <a
              href={`#${heading.id}`}
              class:list={['toc-panel__link', getTextSizeClass(heading.level)]}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}
