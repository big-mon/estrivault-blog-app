{
  "name": "estrivault-blog-app",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-helper.js",
    "build": "pnpm run build:packages:incremental && pnpm --filter astro-blog run build",
    "build:fast": "pnpm -r --filter astro-blog... run build",
    "build:legacy": "pnpm run build:packages && pnpm --filter astro-blog run build",
    "build:packages": "pnpm --parallel --filter @estrivault/cloudinary-utils --filter @estrivault/content-processor --filter @estrivault/og-image-generator run build",
    "build:packages:incremental": "tsc --build packages/cloudinary-utils packages/content-processor packages/og-image-generator",
    "dev:packages": "pnpm --parallel --filter @estrivault/cloudinary-utils --filter @estrivault/og-image-generator run dev",
    "validate:workspace": "node scripts/validate-workspace.js",
    "preinstall": "node scripts/require-pnpm.js",
    "postinstall": "pnpm run build:packages",
    "clean": "pnpm --parallel --filter @estrivault/cloudinary-utils --filter @estrivault/content-processor --filter @estrivault/og-image-generator run clean",
    "clean:ts": "find . -name '.tsbuildinfo*' -delete",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "pnpm run type-check:packages && pnpm --filter astro-blog check",
    "type-check:packages": "pnpm --parallel --filter @estrivault/cloudinary-utils --filter @estrivault/content-processor --filter @estrivault/og-image-generator exec tsc --noEmit",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "@textlint-ja/textlint-rule-preset-ai-writing": "^1.6.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "textlint": "^15.5.2",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "lint-staged": {
    "**/*.{js,ts,svelte}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md,css,scss,astro}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.13.1"
}
